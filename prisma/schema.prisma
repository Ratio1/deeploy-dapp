generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DraftProject {
  projectHash String   @id
  name        String
  color       String
  createdAt   DateTime
  updatedAt   DateTime @updatedAt
  jobs        DraftJob[]

  @@map("draft_projects")
}

model DraftJob {
  id           Int          @id @default(autoincrement())
  projectHash  String
  name         String
  jobType      String
  status       String       @default("draft")
  runningJobId String?
  stripeSubscriptionId     String?
  stripeSubscriptionItemId String?
  stripeCheckoutSessionId  String?
  stripeCustomerId         String?
  txHash       String?
  deeployJobId String?
  deployError  String?
  details      Json
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project DraftProject @relation(fields: [projectHash], references: [projectHash], onDelete: Cascade)

  @@index([projectHash])
  @@index([stripeSubscriptionId])
  @@index([stripeCheckoutSessionId])
  @@map("draft_jobs")
}
